rules_version = '2';
// Trigger workspace sync
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    match /admins/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.token.email == 'kianoshsolheim@gmail.com';
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['name', 'email', 'role', 'createdAt']) && data.keys().size() == 4
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.email is string && data.email.size() >= 0 && data.email.size() <= 100
        && data.role is string && data.role in ['member', 'admin']
        && data.createdAt is timestamp;
    }

    match /articles/{articleId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(articleId) && isValidArticle(incoming()) && incoming().authorId == request.auth.uid && incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidArticle(incoming()) && incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin();
    }

    function isValidArticle(data) {
      return data.keys().hasAll(['title', 'excerpt', 'content', 'date', 'author', 'authorId', 'isPinned', 'createdAt'])
        && data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.excerpt is string && data.excerpt.size() >= 0 && data.excerpt.size() <= 1000
        && data.content is string && data.content.size() > 0 && data.content.size() <= 1048576
        && data.date is string && data.date.size() <= 50
        && data.author is string && data.author.size() > 0 && data.author.size() <= 100
        && data.authorId is string && data.authorId.size() > 0 && data.authorId.size() <= 128
        && data.isPinned is bool
        && (!('imageUrl' in data) || data.imageUrl is string)
        && data.createdAt is timestamp;
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(eventId) && isValidEvent(incoming()) && incoming().createdAt == request.time;
      allow update: if isAdmin() && isValidEvent(incoming()) && incoming().createdAt == existing().createdAt;
      allow delete: if isAdmin();
      
      match /event_articles/{articleId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    function isValidEvent(data) {
      return data.keys().hasAll(['title', 'date', 'location', 'description', 'createdAt']) 
        && data.title is string && data.title.size() > 0 
        && data.date is string && data.date.size() > 0
        && data.location is string
        && data.description is string
        && (!('content' in data) || data.content is string && data.content.size() <= 1048576)
        && data.createdAt is timestamp;
    }

    match /arms/{armId} {
      allow read: if (existing().status == 'approved') || isAdmin() || (isAuthenticated() && existing().ownerId == request.auth.uid);
      allow create: if isAuthenticated() && isValidId(armId) && isValidArm(incoming()) && incoming().ownerId == request.auth.uid && incoming().status == 'pending' && incoming().createdAt == request.time && incoming().updatedAt == request.time;
      allow update: if isAuthenticated() && isValidArm(incoming()) && (
        (isAdmin() && incoming().diff(existing()).affectedKeys().hasAny(['status', 'name', 'description', 'owner', 'updatedAt']) && incoming().createdAt == existing().createdAt && incoming().ownerId == existing().ownerId) ||
        (existing().ownerId == request.auth.uid && existing().status == 'pending' && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'owner', 'updatedAt']) && incoming().status == existing().status && incoming().ownerId == existing().ownerId && incoming().createdAt == existing().createdAt)
      ) && incoming().updatedAt == request.time;
      allow delete: if isAdmin() || (isAuthenticated() && existing().ownerId == request.auth.uid && existing().status == 'pending');
    }

    function isValidArm(data) {
      return data.keys().hasAll(['name', 'description', 'owner', 'ownerId', 'status', 'createdAt', 'updatedAt']) && data.keys().size() == 7
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.description is string && data.description.size() > 0 && data.description.size() <= 5000
        && data.owner is string && data.owner.size() > 0 && data.owner.size() <= 100
        && data.ownerId is string && data.ownerId.size() > 0 && data.ownerId.size() <= 128
        && data.status is string && data.status in ['pending', 'approved']
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }
  }
}
